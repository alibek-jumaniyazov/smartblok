// SmartBlok v3 — enterprise ERP for gazoblock distribution.
// Money totals: Decimal(18,2) UZS. Per-m³ prices: Decimal(18,6) (workbook back-solves
// fractional unit prices from negotiated lump sums, e.g. 732542.438 — totals must
// reproduce exactly). Volumes: Decimal(12,3) m³. All ids opaque UUIDs.
//
// Financial history is immutable: balances are sums over LedgerEntry; cancels/voids
// post compensating (reversal) rows, never delete. Every reversible financial table
// carries reversalOfId; every money-moving row carries a real FK to its actor and
// its source row. Cross-field invariants that Prisma cannot express (account↔party,
// kind↔party, amount sign) are enforced by SQL CHECK constraints in the initial
// migration — see prisma/migrations/*/migration.sql.
//
// Business rules (owner-locked, see docs/audit/excel-spec.md):
//   - client debt recognized at ORDER CREATION
//   - pallets owed IN KIND (count); money ONLY via the explicit lost-pallet charge to a
//     CLIENT. The factory neither charges for a pallet nor pays for one back: orders book
//     palletPrice 0 and a factory return posts no ledger entry at all (DB CHECKs enforce it)
//   - factory cost of an order is PROVISIONAL until factory-payment allocation
//     finalizes it (the allocation's priceKind — from the payment method — picks
//     FACTORY_CASH vs FACTORY_BANK price); partially allocated orders are PARTIAL
//   - bonus programs are versioned per factory, accrue on order COMPLETION,
//     never retroactive; wallet spends = cash withdrawal or factory-debt offset
//   - bonus DEBT_OFFSET canonical chain: Payment(kind=FACTORY_OUT, method=BONUS,
//     no cashbox) → LedgerEntry(source=BONUS_OFFSET, paymentId set)
//     → BonusTransaction(type=DEBT_OFFSET, paymentId set)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── enums ───────────────────────────────

enum Role {
  ADMIN
  ACCOUNTANT
  AGENT
  CASHIER
}

enum OrderStatus {
  NEW
  CONFIRMED
  LOADING
  DELIVERING
  DELIVERED
  COMPLETED
  CANCELLED
}

// Who arranges the truck and, of the money the client owes, who physically hands the
// driver his cut. Transport is INSIDE the goods total for both dealer modes — the client
// owes saleTotal either way; the mode only decides the cash route, so dealer profit is
// identical (saleTotal − cost − transportCost).
enum TransportMode {
  CLIENT_OWN // client sends own truck: no cost, no charge
  DEALER_ABSORBED // dealer hires and pays the driver (VEHICLE_OUT), client pays dealer in full
  CLIENT_PAYS_DRIVER // client hands the driver his cut and the remainder to the dealer (TRANSPORT_DIRECT)
  DEALER_CHARGED // DEPRECATED — transport billed ON TOP of the goods total. Retained so
  // historical rows keep rendering; rejected on new/edited orders (see orders.service).
}

enum TransportPaidStatus {
  NOT_APPLICABLE
  UNKNOWN // workbook blank — imported as-is, must be resolved by owner
  UNPAID
  PAID // dealer paid the driver
  PAID_BY_CLIENT // client paid the driver directly («шопр учун барди»)
}

enum PaymentKind {
  CLIENT_IN // client pays dealer
  CLIENT_REFUND // dealer returns money to client
  FACTORY_OUT // dealer pays factory
  FACTORY_REFUND // factory returns money (draws down the prepaid advance)
  VEHICLE_OUT // dealer pays driver/truck
  TRANSPORT_DIRECT // client pays driver directly: credits client, settles vehicle, NO kassa row
}

enum PaymentMethod {
  CASH
  BANK
  CLICK
  TERMINAL
  CARD // cash-to-card («Нахт пластика»)
  USD // foreign-cash channel; UZS value = usdAmount × rate, stored in amount
  BONUS // factory payment funded from the bonus wallet (debt offset; cashbox stays null)
}

enum PriceKind {
  FACTORY_CASH
  FACTORY_BANK
  DEALER_SALE
}

// How the dealer INTENDS to pay the factory for this order (owner's three buttons).
// CASH/BANK lock the provisional cost basis; UNKNOWN means "not decided yet" — the
// order shows BOTH candidate costs and may be settled in a MIX (part cash-priced,
// part bank-priced). An UNKNOWN order posts its provisional ORDER_COST at the BANK
// (dearer) price so the factory debt is never understated, and it is excluded from
// realized-profit reporting until settlement determines the real cost.
enum FactoryPayIntent {
  CASH
  BANK
  UNKNOWN
}

// Sub-account of the FACTORY ledger. The dealer's money at the factory does NOT
// auto-consume his order debt (owner rule, 2026-07-21): prepayments sit in an
// ADVANCE_* bucket, order costs sit in PAYABLE, and only an explicit «avansdan
// yechish» draw moves value between them (a zero-sum pair of ADVANCE_DRAW rows).
// Σ over all three buckets == the old single netted FACTORY balance, so every
// historical aggregate keeps its value.
enum FactoryBucket {
  PAYABLE // <0 ⇒ dealer owes the factory for goods
  ADVANCE_CASH // >0 ⇒ naqd money standing at the factory
  ADVANCE_BANK // >0 ⇒ o'tkazma money standing at the factory
}

enum CostStatus {
  PROVISIONAL // costed at intended-method price; factory debt may still move
  PARTIAL // some allocations exist but the order is not fully covered
  FINAL // fixed by factory-payment allocation (or manual finalize)
}

enum BonusProgramKind {
  NONE
  PER_M3 // fixed UZS per m³ purchased
  PERCENT // % of the factory purchase amount (blocks, at applicable factory price)
}

enum BonusTransactionType {
  ACCRUAL // on order COMPLETED (base recorded in baseAmount/baseM3)
  WITHDRAWAL // paid out through kassa (cash leaves a cashbox)
  DEBT_OFFSET // applied to reduce debt to the same factory
  ADJUSTMENT // manual correction (audit-logged), signed
  REVERSAL // compensating entry (e.g. order un-completed)
}

enum LedgerAccount {
  CLIENT // >0 ⇒ client owes dealer
  FACTORY // >0 ⇒ dealer has advance at factory; <0 ⇒ dealer owes factory
  VEHICLE // <0 ⇒ dealer owes the vehicle/driver
}

enum LedgerSource {
  ORDER_SALE // client charged for goods
  ORDER_COST // dealer owes factory for BLOCKS only (pallets are in-kind, never billed)
  COST_ADJUSTMENT // provisional → final cost delta (links the order)
  TRANSPORT_CHARGE // client charged for transport
  TRANSPORT_COST // dealer owes driver
  TRANSPORT_CLIENT_DIRECT // client hands the driver his cut directly — carved out of his sale debt
  PAYMENT
  PAYMENT_VOID
  ORDER_CANCEL
  PALLET_CHARGE // lost pallets charged to client (links palletTransactionId)
  PALLET_RETURN_CREDIT // RETIRED 2026-07-21 — pallets are count-only at the factory, a
  // return earns no money. Historical rows keep rendering; a new one is BLOCKED by the
  // ledger_no_pallet_return_credit CHECK (migration 20260723120000).
  BONUS_OFFSET // bonus wallet applied to factory debt (paymentId required)
  ADVANCE_DRAW // «avansdan yechish»: zero-sum pair moving ADVANCE_CASH|ADVANCE_BANK → PAYABLE
  // for one order. Both rows carry orderId + allocationId; reversing them un-draws.
  ADJUSTMENT // manual, audit-logged
  OFFBOOK_ADJUSTMENT // «balansni nazorat qilish» — an owner off-book correction that moves ONE
  // party's own balance + statement, but is EXCLUDED from the dashboard company rollups and the
  // transactions journal (posts no CashTransaction/Payment). Owner rule, 2026-07-22.
  IMPORT
}

enum PalletTransactionType {
  RECEIVED_FROM_FACTORY // pallets bought with a truck (purchase side)
  DELIVERED_TO_CLIENT // pallets that went to the client with a truck
  RETURNED_BY_CLIENT
  RETURNED_TO_FACTORY // sent back to factory — COUNT ONLY, never money (unitPrice must stay NULL)
  CHARGED_LOST // converted to money on the client ledger
  ADJUSTMENT // signed qty
  REVERSAL // signed qty, mirrors reversalOf
}

enum CashboxType {
  CASH
  BANK
  CLICK
  TERMINAL
  CARD
}

enum Currency {
  UZS
  USD
}

enum CashDirection {
  IN
  OUT
}

enum CashSource {
  MANUAL
  PAYMENT
  EXPENSE
  BONUS_WITHDRAWAL
  REVERSAL // reversalOfId points at the row being reversed
  TRANSFER // box→box move: paired IN/OUT rows share transferPairId
  CAPITAL // dealer's own money put in to keep a box from going below zero (import)
  // «kassa balansini tahrirlash» — an owner off-book correction of ONE box's balance. A REAL
  // row is written (that is how the balance moves), but it is EXCLUDED from every kirim/chiqim
  // flow figure and is NOT storno-able — a wrong correction is fixed by setting the balance
  // again. Stays visible in the journal as the audit trail. Owner rule, 2026-07-23.
  BALANCE_ADJUSTMENT
}

enum LegalEntityKind {
  DEALER // owner's own firms (Септем Алока, Септем семент, …)
  FACTORY // factory firms ("CAOLS KS" MCHJ)
  THIRD_PARTY // client-side payer firms
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VOID
  STATUS_CHANGE
  COST_FINALIZE
  LOGIN
  LOGIN_FAILED
  IMPORT
  EXPORT
}

// ─────────────────────────── platform ───────────────────────────

model AppSetting {
  key       String   @id // agentDebtLimitDefault (null value ⇒ unlimited), truckCapacityPallets, saleMarginMinPct, …
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String?   @unique
  password     String
  name         String
  role         Role      @default(AGENT)
  phone        String?
  active       Boolean   @default(true)
  tokenVersion Int       @default(0) // bump to invalidate all existing JWTs
  agentId      String?
  agent        Agent?    @relation(fields: [agentId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs          AuditLog[]
  orderStatusChanges OrderStatusHistory[]
  documents          Document[]
  importBatches      ImportBatch[]
  ordersCreated      Order[]              @relation("OrderCreatedBy")
  orderComments      OrderComment[]
  paymentsCreated    Payment[]            @relation("PaymentCreatedBy")
  paymentsVoided     Payment[]            @relation("PaymentVoidedBy")
  allocationsCreated PaymentAllocation[]  @relation("AllocationCreatedBy")
  allocationsVoided  PaymentAllocation[]  @relation("AllocationVoidedBy")
  ledgerEntries      LedgerEntry[]        @relation("LedgerCreatedBy")
  palletTransactions PalletTransaction[]  @relation("PalletCreatedBy")
  bonusTransactions  BonusTransaction[]   @relation("BonusCreatedBy")
  cashTransactions   CashTransaction[]    @relation("CashCreatedBy")
  expensesCreated    Expense[]            @relation("ExpenseCreatedBy")

  @@index([agentId])
}

model AuditLog {
  id       String      @id @default(uuid())
  at       DateTime    @default(now())
  userId   String?
  user     User?       @relation(fields: [userId], references: [id])
  action   AuditAction
  entity   String // model name, e.g. "Order"
  entityId String?
  before   Json?
  after    Json?
  ip       String?
  note     String?

  @@index([entity, entityId])
  @@index([userId, at])
  @@index([at])
}

model LegalEntity {
  id     String          @id @default(uuid())
  name   String          @unique
  kind   LegalEntityKind @default(THIRD_PARTY)
  inn    String?
  note   String?
  active Boolean         @default(true)

  cashboxes       Cashbox[]
  paymentsAsPayer Payment[] @relation("PayerEntity")
  paymentsAsPayee Payment[] @relation("ReceiverEntity")
}

// ─────────────────────────── parties ───────────────────────────

model Region {
  id      String           @id @default(uuid())
  name    String           @unique
  note    String?
  clients Client[]
  routes  LogisticsRoute[]
}

model Agent {
  id        String   @id @default(uuid())
  name      String   @unique
  phone     String?
  sortNo    Int? // display ordering only (workbook numbers carry no logic)
  debtLimit Decimal? @db.Decimal(18, 2) // max Σ of his clients' debt; null ⇒ AppSetting default; 0 ⇒ new orders blocked
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients  Client[]
  orders   Order[]
  payments Payment[]
  users    User[]
}

model Client {
  id              String   @id @default(uuid())
  name            String   @unique
  legalEntity     String?
  phone           String?
  regionId        String?
  region          Region?  @relation(fields: [regionId], references: [id])
  agentId         String?
  agent           Agent?   @relation(fields: [agentId], references: [id])
  creditLimit     Decimal? @db.Decimal(18, 2) // null ⇒ unlimited; 0 ⇒ no credit (prepay only)
  paymentTermDays Int? // default collection horizon; order.dueDate = order.date + termDays
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  aliases            ClientAlias[]
  prices             ClientPrice[]
  orders             Order[]
  payments           Payment[]
  ledgerEntries      LedgerEntry[]
  palletTransactions PalletTransaction[]
  documents          Document[]

  @@index([agentId])
  @@index([regionId])
}

model ClientAlias {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String @unique // spelling variant seen in imports («Жаср Версал», "NORMAT UMIDBEK")

  @@index([clientId])
}

// per-client special sale price (prompt: "unless special pricing exists")
model ClientPrice {
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  pricePerM3    Decimal  @db.Decimal(18, 6)
  effectiveFrom DateTime @default(now())
  createdBy     String?

  @@unique([clientId, productId, effectiveFrom])
  @@index([clientId, productId, effectiveFrom])
}

model Factory {
  id        String   @id @default(uuid())
  name      String   @unique
  note      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products           Product[]
  orders             Order[]
  payments           Payment[]
  bonusPrograms      BonusProgram[]
  bonusTransactions  BonusTransaction[]
  ledgerEntries      LedgerEntry[]
  palletTransactions PalletTransaction[]
  routes             LogisticsRoute[]
}

// Versioned: never UPDATE a row — insert a new one with a later effectiveFrom.
// The program in force at order COMPLETION time governs that order's accrual, forever.
model BonusProgram {
  id            String           @id @default(uuid())
  factoryId     String
  factory       Factory          @relation(fields: [factoryId], references: [id])
  kind          BonusProgramKind
  ratePerM3     Decimal?         @db.Decimal(18, 2) // kind=PER_M3
  percent       Decimal?         @db.Decimal(5, 2) // kind=PERCENT, of factory purchase amount
  effectiveFrom DateTime         @default(now())
  createdBy     String?
  createdAt     DateTime         @default(now())

  accruals BonusTransaction[]

  @@unique([factoryId, effectiveFrom])
  @@index([factoryId, effectiveFrom])
}

model BonusTransaction {
  id        String               @id @default(uuid())
  at        DateTime             @default(now())
  factoryId String
  factory   Factory              @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  type      BonusTransactionType
  amount    Decimal              @db.Decimal(18, 2) // signed: ACCRUAL +, WITHDRAWAL/DEBT_OFFSET −

  // accrual audit base: what the amount was computed from
  baseAmount Decimal? @db.Decimal(18, 2) // PERCENT: factory purchase amount used
  baseM3     Decimal? @db.Decimal(12, 3) // PER_M3: volume used

  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  programId String?
  program   BonusProgram? @relation(fields: [programId], references: [id], onDelete: Restrict)
  paymentId String?       @unique // DEBT_OFFSET: the Payment(method=BONUS) it funds
  payment   Payment?      @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  note         String?
  createdById  String?
  createdBy    User?             @relation("BonusCreatedBy", fields: [createdById], references: [id])
  reversalOfId String?           @unique
  reversalOf   BonusTransaction? @relation("BonusReversal", fields: [reversalOfId], references: [id])
  reversedBy   BonusTransaction? @relation("BonusReversal")

  cashTransactions CashTransaction[] // WITHDRAWAL kassa rows

  @@index([factoryId, at])
  @@index([orderId])
  @@index([programId])
}

// ─────────────────────────── catalog ───────────────────────────

model Product {
  id              String   @id @default(uuid())
  factoryId       String
  factory         Factory  @relation(fields: [factoryId], references: [id])
  name            String
  size            String? // "600x300x200"
  m3PerPallet     Decimal  @default(1.728) @db.Decimal(6, 3) // 1.728 for ×200, 1.8 for ×250
  blocksPerPallet Int?
  unit            String   @default("m³")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prices       ProductPrice[]
  clientPrices ClientPrice[]
  orderItems   OrderItem[]

  @@unique([factoryId, name])
  @@index([factoryId])
}

// versioned three-price book: FACTORY_CASH / FACTORY_BANK / DEALER_SALE
model ProductPrice {
  id            String    @id @default(uuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind          PriceKind
  pricePerM3    Decimal   @db.Decimal(18, 6)
  effectiveFrom DateTime  @default(now())
  createdBy     String?

  @@unique([productId, kind, effectiveFrom])
  @@index([productId, kind, effectiveFrom])
}

model Vehicle {
  id              String   @id @default(uuid())
  name            String
  // plate is unique ONLY for real (non-oneTime) vehicles, and on the NORMALIZED key
  // (upper + Cyrillic->Latin + all spaces stripped) rather than the raw text — so
  // «90 x 700 ca», «90X700CA» and «90 Х 700 СА» are ONE truck. The constraint is a
  // PARTIAL EXPRESSION unique index living in raw SQL:
  //   20260713140000 (partial, byte-exact) -> 20260721120000 (partial, normalized).
  // It must stay in lockstep with plateKey() in src/common/plate.ts.
  // Prisma can express neither partial nor expression indexes, so `@unique` is dropped
  // here. FORBIDDEN: `prisma db push` (it would recreate a full byte-exact unique).
  // Use migrate deploy/reset only.
  // NULL plates are exempt: any number of trucks may have no plate.
  plate           String?
  driver          String?
  phone           String?
  capacityPallets Int      @default(19)
  active          Boolean  @default(true)
  // one-time / ad-hoc truck: not permanently saved, hidden from the picker, but its
  // transport is still charged/paid (a real row is needed for the VEHICLE ledger FK).
  oneTime         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders        Order[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]
}

model LogisticsRoute {
  id              String   @id @default(uuid())
  factoryId       String
  factory         Factory  @relation(fields: [factoryId], references: [id])
  regionId        String
  region          Region   @relation(fields: [regionId], references: [id])
  costPerTruck    Decimal  @db.Decimal(18, 2)
  capacityPallets Int      @default(19)
  effectiveFrom   DateTime @default(now())

  @@unique([factoryId, regionId, effectiveFrom])
  @@index([factoryId, regionId, effectiveFrom])
}

// ─────────────────────────── orders ───────────────────────────

// One order = one truck (split loads = multiple items on the truck).
// All items must belong to Order.factoryId's products (service-enforced).
model Order {
  id      String      @id @default(uuid())
  // Generated as 'ORD-' + nextval('order_no_seq'). That Postgres SEQUENCE lives ONLY
  // in raw SQL (migration 20260710235000); `prisma db push` would not create it and
  // order creation would fail. FORBIDDEN: use migrate deploy/reset only, never db push.
  orderNo String      @unique
  date    DateTime
  dueDate DateTime? // expected collection date (client.paymentTermDays)
  status  OrderStatus @default(NEW)

  agentId    String? // snapshot of the client's agent at order time (agent KPIs are historical)
  agent      Agent?   @relation(fields: [agentId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  factoryId  String
  factory    Factory  @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  vehicleId  String?
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  driverName String? // snapshot; Vehicle.driver may change later

  // denormalized item sums, recomputed server-side inside the same transaction
  saleTotal  Decimal    @default(0) @db.Decimal(18, 2) // Σ items m³ × salePricePerM3 (excl. transport)
  // Σ items BLOCK cost only — pallets are in-kind (count), never money (owner rule 2026-07-21).
  costTotal  Decimal    @default(0) @db.Decimal(18, 2)
  costStatus CostStatus @default(PROVISIONAL)

  // Which factory price book the dealer means to buy at. UNKNOWN ⇒ undecided: both
  // candidate costs are shown and the order may settle as a cash/bank MIX.
  factoryPayIntent FactoryPayIntent @default(UNKNOWN)

  // transport (per truck); transport profit = transportCharge − transportCost
  transportMode       TransportMode       @default(DEALER_ABSORBED)
  transportCost       Decimal             @default(0) @db.Decimal(18, 2) // dealer → driver
  transportCharge     Decimal             @default(0) @db.Decimal(18, 2) // dealer → client (DEALER_CHARGED)
  transportPaidStatus TransportPaidStatus @default(NOT_APPLICABLE)
  transportPaidAt     DateTime?

  note            String?
  cancelReason    String?
  cancelledAt     DateTime?
  completedAt     DateTime? // bonus accrual reference point
  costFinalizedAt DateTime?
  loadedAt        DateTime? // truck loaded at factory — actual qty captured (LOADING)
  loadedById      String? // who entered the actual load (audit snapshot)
  createdById     String?
  createdBy       User?        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  importBatchId   String?
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id])

  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  comments           OrderComment[]
  allocations        PaymentAllocation[]
  ledgerEntries      LedgerEntry[]
  palletTransactions PalletTransaction[]
  bonusTransactions  BonusTransaction[]
  documents          Document[]

  @@index([clientId, status])
  @@index([factoryId, status])
  @@index([agentId, status])
  @@index([vehicleId])
  @@index([status, date])
  @@index([date])
  @@index([dueDate])
  @@index([importBatchId])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantityM3  Decimal @db.Decimal(12, 3) // planned (ordered) volume
  palletCount Int     @default(0)
  // ALWAYS 0 on new orders — a pallet is an in-kind deposit, not a cost component. Kept
  // for historical rows written before the rule was locked; the API rejects a palletPrice.
  palletPrice Decimal @default(0) @db.Decimal(18, 2)

  // Actual delivered qty, entered at LOADING (zavoddan chiqqach yuk o'zgarishi mumkin).
  // null ⇒ actual == planned; when set, all totals + the 3 ledger levels recompute off
  // the actual via append-only *_ADJUSTMENT delta rows (never overwrites the original charge).
  actualQuantityM3  Decimal? @db.Decimal(12, 3)
  actualPalletCount Int?

  // sale side (client). Discount is derivable: (listPricePerM3 − salePricePerM3) × m³.
  listPricePerM3 Decimal? @db.Decimal(18, 6) // price-book value resolved at creation
  salePricePerM3 Decimal  @default(0) @db.Decimal(18, 6) // actual; lump-sum entry back-solves it
  saleTotal      Decimal  @default(0) @db.Decimal(18, 2) // m³ × salePricePerM3, rounded 2dp (pallets NOT billed)
  // negotiated FIXED total (kelishilgan qat'iy summa): when set, the sale does NOT
  // scale with actual quantity on reconcile. null = per-m³ (scales with actual m³).
  saleLumpSum    Decimal? @db.Decimal(18, 2)
  pricePending   Boolean  @default(false) // shipped before price agreed

  // cost side (factory): provisional at creation, finalized by payment allocation.
  // costTotal always reflects the CURRENT best-known cost; the provisional→final
  // delta is posted as a COST_ADJUSTMENT ledger entry (immutable trail).
  provisionalPriceKind PriceKind @default(FACTORY_BANK)
  costPricePerM3       Decimal   @default(0) @db.Decimal(18, 6)
  finalCostPricePerM3  Decimal?  @db.Decimal(18, 6)
  costTotal            Decimal   @default(0) @db.Decimal(18, 2) // m³ × costPrice (pallets add nothing)

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id      String       @id @default(uuid())
  orderId String
  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  from    OrderStatus?
  to      OrderStatus
  at      DateTime     @default(now())
  byId    String?
  by      User?        @relation(fields: [byId], references: [id])
  note    String?

  @@index([orderId, at])
}

model OrderComment {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  byId      String?
  by        User?    @relation(fields: [byId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

// ─────────────────────────── money ───────────────────────────

// Payment→order linkage lives ONLY in PaymentAllocation (single source of truth).
model Payment {
  id   String      @id @default(uuid())
  date DateTime
  kind PaymentKind

  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  factoryId String?
  factory   Factory? @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  method        PaymentMethod @default(CASH)
  amount        Decimal       @db.Decimal(18, 2) // always UZS
  usdAmount     Decimal       @default(0) @db.Decimal(18, 2)
  rate          Decimal       @default(0) @db.Decimal(12, 2)
  denominations Json? // optional cash breakdown {"5000": n, …}

  payerEntityId    String?
  payerEntity      LegalEntity? @relation("PayerEntity", fields: [payerEntityId], references: [id])
  receiverEntityId String?
  receiverEntity   LegalEntity? @relation("ReceiverEntity", fields: [receiverEntityId], references: [id])
  payerName        String? // free text when no LegalEntity record
  receiverName     String? // free text (e.g. factory card № 9860…)

  cashboxId    String?
  cashbox      Cashbox? @relation(fields: [cashboxId], references: [id], onDelete: Restrict)
  // Second cashbox for a MIXED naqd (CASH) payment: the UZS part lands in `cashbox`
  // (a UZS kassa box) and the USD part lands here (a USD kassa box). Null otherwise.
  usdCashboxId String?
  usdCashbox   Cashbox? @relation("PaymentUsdCashbox", fields: [usdCashboxId], references: [id], onDelete: Restrict)

  idempotencyKey String?   @unique // client-generated; blocks double-submit
  note           String?
  voidedAt       DateTime?
  voidReason     String?
  voidedById     String?
  voidedBy       User?     @relation("PaymentVoidedBy", fields: [voidedById], references: [id])
  createdById    String?
  createdBy      User?     @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  // false ⇒ imported from client account sheets, absent in the Оплата ledger
  // (~95.8M gap) — needs owner review. TRANSPORT_DIRECT rows are reconciled=true
  // by definition (they never touch dealer cash).
  reconciled    Boolean      @default(true)

  allocations      PaymentAllocation[]
  ledgerEntries    LedgerEntry[]
  cashTransactions CashTransaction[]
  bonusTransaction BonusTransaction?

  @@index([clientId, date])
  @@index([factoryId, date])
  @@index([vehicleId])
  @@index([agentId, date])
  @@index([kind, date])
  @@index([cashboxId])
  @@index([usdCashboxId])
  @@index([reconciled])
  @@index([date])
  @@index([payerEntityId])
  @@index([receiverEntityId])
}

// Allocates a payment to specific orders.
// NOTE: the partial unique index "PaymentAllocation_active_pair" (one ACTIVE
// allocation per payment→order pair — the guard against double-finalizing cost)
// lives ONLY in raw SQL (migration 20260711003000). Prisma cannot express it, so
// `prisma db push` would silently drop it. FORBIDDEN: use migrate deploy/reset only.
// CLIENT_IN: settles client debt per order (aging).
// FACTORY_OUT: finalizes order cost — priceKind (from the payment's method at
// allocation time) picks FACTORY_CASH vs FACTORY_BANK. costStatus → PARTIAL when
// Σ active allocations < costTotal, FINAL when fully covered; the finalizing
// service posts the COST_ADJUSTMENT ledger delta.
// Voided allocations stay as rows (voidedAt) — active-uniqueness is service-enforced.
model PaymentAllocation {
  id        String  @id @default(uuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  amount    Decimal @db.Decimal(18, 2)

  priceKind   PriceKind? // FACTORY_OUT only: cost basis this allocation applies
  createdAt   DateTime   @default(now())
  createdById String?
  createdBy   User?      @relation("AllocationCreatedBy", fields: [createdById], references: [id])
  voidedAt    DateTime?
  voidReason  String?
  voidedById  String?
  voidedBy    User?      @relation("AllocationVoidedBy", fields: [voidedById], references: [id])
  // true ⇒ born from «avansdan yechish» (money already standing at the factory) rather
  // than from a fresh payment. Drives the ADVANCE_DRAW ledger pair below.
  fromAdvance Boolean    @default(false)

  ledgerEntries LedgerEntry[]

  @@index([paymentId])
  @@index([orderId])
}

// Immutable postings. Balance(party) = Σ amount over the party's account.
// Convention: >0 ⇒ asset for the dealer (client owes us / our advance at factory);
//             <0 ⇒ dealer's liability (we owe factory/vehicle).
// SQL CHECKs (migration): exactly the party matching `account` is set;
// amount ≠ 0; source=BONUS_OFFSET ⇒ paymentId NOT NULL;
// source IN (PALLET_CHARGE, PALLET_RETURN_CREDIT) ⇒ palletTransactionId NOT NULL;
// source ≠ PALLET_RETURN_CREDIT (retired — a factory pallet return moves no money).
model LedgerEntry {
  id      String        @id @default(uuid())
  at      DateTime      @default(now())
  date    DateTime // business date
  account LedgerAccount
  source  LedgerSource
  amount  Decimal       @db.Decimal(18, 2) // signed

  // Required for (and only for) account=FACTORY — SQL CHECK ledger_factory_bucket.
  // Splits the factory account into open order debt vs the two advance channels so a
  // prepayment never silently pays off an order. Σ(buckets) == the legacy net balance.
  factoryBucket FactoryBucket?

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  factoryId String?
  factory   Factory? @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  // ADVANCE_DRAW only: the allocation this draw funds. Both rows of the zero-sum pair
  // carry it, so voiding one allocation reverses exactly its own two rows.
  allocationId String?
  allocation   PaymentAllocation? @relation(fields: [allocationId], references: [id], onDelete: Restrict)

  palletTransactionId String?            @unique // PALLET_CHARGE money side (+ retired PALLET_RETURN_CREDIT rows)
  palletTransaction   PalletTransaction? @relation(fields: [palletTransactionId], references: [id], onDelete: Restrict)

  note          String?
  createdById   String?
  createdBy     User?        @relation("LedgerCreatedBy", fields: [createdById], references: [id])
  reversalOfId  String?      @unique
  reversalOf    LedgerEntry? @relation("LedgerReversal", fields: [reversalOfId], references: [id])
  reversedBy    LedgerEntry? @relation("LedgerReversal")
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([account, clientId, date])
  @@index([account, factoryId, date])
  @@index([account, factoryId, factoryBucket])
  @@index([account, vehicleId, date])
  @@index([source, date])
  @@index([orderId])
  @@index([paymentId])
  @@index([allocationId])
  @@index([date])
}

// Pallet movements — in units. qty sign convention: positive for the four
// directional types (type carries the direction in the balance formula);
// SIGNED for ADJUSTMENT and REVERSAL.
// Client pallet balance = Σ(DELIVERED_TO_CLIENT) − Σ(RETURNED_BY_CLIENT)
//   − Σ(CHARGED_LOST) + Σ(signed client ADJUSTMENT/REVERSAL rows).
model PalletTransaction {
  id   String                @id @default(uuid())
  at   DateTime              @default(now())
  date DateTime
  type PalletTransactionType
  qty  Int

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  factoryId String?
  factory   Factory? @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Restrict)

  // CHARGED_LOST ONLY — the price a client is billed for a pallet he lost. The factory
  // side is in-kind: `pallet_factory_return_moneyless` CHECK forbids a price on
  // RETURNED_TO_FACTORY rows (migration 20260723120000).
  unitPrice Decimal? @db.Decimal(18, 2)

  note          String?
  createdById   String?
  createdBy     User?              @relation("PalletCreatedBy", fields: [createdById], references: [id])
  reversalOfId  String?            @unique
  reversalOf    PalletTransaction? @relation("PalletReversal", fields: [reversalOfId], references: [id])
  reversedBy    PalletTransaction? @relation("PalletReversal")
  ledgerEntry   LedgerEntry?
  importBatchId String?
  importBatch   ImportBatch?       @relation(fields: [importBatchId], references: [id])

  @@index([clientId, type])
  @@index([factoryId, type])
  @@index([orderId])
  @@index([date])
}

// ─────────────────────────── kassa ───────────────────────────

model Cashbox {
  id        String       @id @default(uuid())
  name      String       @unique
  type      CashboxType  @default(CASH)
  currency  Currency     @default(UZS)
  entityId  String?
  entity    LegalEntity? @relation(fields: [entityId], references: [id])
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  transactions CashTransaction[]
  payments     Payment[]
  usdPayments  Payment[]         @relation("PaymentUsdCashbox")
  expenses     Expense[]

  @@index([entityId])
}

model CashTransaction {
  id        String        @id @default(uuid())
  cashboxId String
  cashbox   Cashbox       @relation(fields: [cashboxId], references: [id], onDelete: Restrict)
  date      DateTime      @default(now())
  direction CashDirection
  amount    Decimal       @db.Decimal(18, 2) // in the cashbox currency, > 0
  rate      Decimal       @default(0) @db.Decimal(12, 2)
  source    CashSource    @default(MANUAL)

  paymentId          String?
  payment            Payment?          @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  expenseId          String?
  expense            Expense?          @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  bonusTransactionId String?
  bonusTransaction   BonusTransaction? @relation(fields: [bonusTransactionId], references: [id], onDelete: Restrict)

  note          String?
  createdById   String?
  createdBy     User?            @relation("CashCreatedBy", fields: [createdById], references: [id])
  reversalOfId  String?          @unique
  reversalOf    CashTransaction? @relation("CashReversal", fields: [reversalOfId], references: [id])
  reversedBy    CashTransaction? @relation("CashReversal")
  // source=TRANSFER: the paired IN and OUT rows of one box→box move share this id.
  transferPairId String?
  importBatchId String?
  importBatch   ImportBatch?     @relation(fields: [importBatchId], references: [id])
  createdAt     DateTime         @default(now())

  @@index([cashboxId, direction])
  @@index([cashboxId, date])
  @@index([paymentId])
  @@index([expenseId])
  @@index([bonusTransactionId])
  @@index([source])
  @@index([date])
  @@index([transferPairId])
}

model ExpenseCategory {
  id       String    @id @default(uuid())
  name     String    @unique
  expenses Expense[]
}

model Expense {
  id          String           @id @default(uuid())
  date        DateTime
  categoryId  String?
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id])
  amount      Decimal          @db.Decimal(18, 2)
  cashboxId   String?
  cashbox     Cashbox?         @relation(fields: [cashboxId], references: [id], onDelete: Restrict)
  note        String?
  voidedAt    DateTime?
  voidReason  String?
  createdById String?
  createdBy   User?            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  cashTransactions CashTransaction[]
  importBatchId    String?
  importBatch      ImportBatch?      @relation(fields: [importBatchId], references: [id])

  @@index([categoryId])
  @@index([cashboxId])
  @@index([date])
}

// ─────────────────────────── attachments / import ───────────────────────────

model Document {
  id           String   @id @default(uuid())
  filename     String
  storedPath   String
  mime         String?
  size         Int?
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([clientId])
}

// ─────────────────────── import staging ───────────────────────
// No financial table lives here. The owner's workbook lands HERE, is edited
// HERE, and only one function (ImportCommitService.run) copies it into the live
// tables inside one $transaction. Nothing persists to the ledger before commit.

enum ImportBatchStatus {
  PARSING
  DRAFT
  READY
  COMMITTING
  COMMITTED
  ROLLED_BACK
  DISCARDED
  FAILED
}

enum ImportRowKind {
  SHIPMENT
  CLIENT_PAYMENT
  FACTORY_PAYMENT
  PALLET_RETURN
  SHEET_BALANCE
}

enum ImportRowStatus {
  PENDING
  READY
  SKIPPED
  COMMITTED
  FAILED
}

enum ImportIssueSeverity {
  BLOCK // must be fixed before commit
  CONFIRM // system proposes; owner says yes/no
  WARN // acknowledge-to-pass
  INFO
}

enum ImportIssueStatus {
  OPEN
  ACCEPTED
  EDITED
  IGNORED
}

enum ImportEntityKind {
  CLIENT
  AGENT
  VEHICLE
  PRODUCT
  FACTORY
  LEGAL_ENTITY
}

enum ImportEntityDecision {
  PENDING
  LINK
  CREATE
  SKIP
}

model ImportBatch {
  id            String            @id @default(uuid())
  filename      String
  status        ImportBatchStatus @default(PARSING)
  sourceHash    String? // sha256(bytes) — detects re-upload of the same file
  rulesSnapshot Json? // which rules/thresholds were in force
  decisions     Json? // owner's answers to the questions only they can settle
  preview       Json? // last dry-run result (balances the owner sees before commit)
  previewHash   String? // commit confirmToken must equal this
  previewAt     DateTime?
  stats         Json? // excelRow → entityId + original broken values (Разница/Общая прибль)
  error         String?
  committedAt   DateTime?
  rolledBackAt  DateTime?
  createdById   String?
  createdBy     User?             @relation(fields: [createdById], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt

  rows         ImportRow[]
  issues       ImportIssue[]
  entityMaps   ImportEntityMap[]
  fingerprints ImportFingerprint[]

  // existing back-refs — unchanged
  orders             Order[]
  payments           Payment[]
  ledgerEntries      LedgerEntry[]
  palletTransactions PalletTransaction[]
  cashTransactions   CashTransaction[]
  expenses           Expense[]

  @@index([status, createdAt])
}

/// One Excel row. Three layers: raw → parsed → resolved. COMMIT reads ONLY resolvedJson.
model ImportRow {
  id        String        @id @default(uuid())
  batchId   String
  batch     ImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  kind      ImportRowKind
  sheetName String // «Товар», «3-Сулаймон…» (trailing space preserved verbatim)
  excelRow  Int // the owner's coordinate — shown in the review UI
  seq       Int

  rawJson      Json // per-column cell VALUE + TYPE (type matters: col S text vs number)
  parsedJson   Json
  resolvedJson Json // + owner edits + resolved foreign keys

  status      ImportRowStatus @default(PENDING)
  groupKey    String? // one groupKey = one Order, N OrderItems (two sizes on one truck)
  fingerprint String // sha256(kind|client|date|plate|m3|amount)

  orderId             String?
  paymentId           String?
  palletTransactionId String?
  editedById          String?
  editedAt            DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  issues              ImportIssue[]

  @@unique([batchId, sheetName, excelRow])
  @@index([batchId, kind, status])
  @@index([batchId, groupKey])
  @@index([fingerprint])
}

/// rowId = null ⇒ a batch-wide decision (the owner's questions live here too).
model ImportIssue {
  id      String      @id @default(uuid())
  batchId String
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowId   String?
  row     ImportRow?  @relation(fields: [rowId], references: [id], onDelete: Cascade)

  ruleId         String // = Settings key (e.g. FOYDA_PODDON_QOSHILGAN)
  severity       ImportIssueSeverity // effective level after AppSetting override
  field          String? // resolvedJson path: 'clientId', 'costPricePerM3'
  message        String // Uzbek, full sentence
  currentValue   Json?
  suggestedValue Json? // null ⇒ no safe suggestion; owner types their own

  status        ImportIssueStatus @default(OPEN)
  resolvedValue Json?
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime          @default(now())

  @@index([batchId, status, severity])
  @@index([batchId, ruleId])
  @@index([rowId])
}

/// name → entity. «Нормат Умидбек» and "NORMAT UMIDBEK" resolve to one Client.
model ImportEntityMap {
  id              String               @id @default(uuid())
  batchId         String
  batch           ImportBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  kind            ImportEntityKind
  sourceName      String // raw string, exact
  normalizedKey   String // matcher key
  occurrences     Int                  @default(1)
  sampleRows      Json? // ["Товар r41","Оплата r21"]
  decision        ImportEntityDecision @default(PENDING)
  targetId        String?
  newName         String?
  createPayload   Json?
  suggestion      Json? // {targetId, confidence, reason}
  createdEntityId String?

  @@unique([batchId, kind, normalizedKey])
  @@index([batchId, kind, decision])
}

/// Cross-batch dedup guard: a committed fingerprint blocks re-import. Removed on rollback.
model ImportFingerprint {
  key       String        @id
  batchId   String
  batch     ImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  kind      ImportRowKind
  entityId  String
  createdAt DateTime      @default(now())

  @@index([batchId])
}

// ─────────────────────────── AI chat ───────────────────────────
// Saqlanadigan AI suhbatlar (Haiku). userId — egasi (o‘zi ko‘radi/o‘chiradi).
model ChatConversation {
  id        String        @id @default(uuid())
  userId    String?
  title     String        @default("Yangi suhbat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}
