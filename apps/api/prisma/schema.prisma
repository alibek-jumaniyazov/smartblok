// SmartBlok v2 — order-lifecycle ERP. All ids are opaque UUIDs (no sequential enumeration).
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String
  role      String   @default("AGENT") // ADMIN | ACCOUNTANT | AGENT | CASHIER
  phone     String?
  active    Boolean  @default(true)
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
}

model Agent {
  id        String    @id @default(uuid())
  name      String    @unique
  phone     String?
  groupNo   Int?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  clients   Client[]
  orders    Order[]
  payments  Payment[]
  users     User[]
}

model Region {
  id      String           @id @default(uuid())
  name    String           @unique
  note    String?
  clients Client[]
  routes  LogisticsRoute[]
}

model Client {
  id          String    @id @default(uuid())
  name        String    @unique
  legalEntity String?
  phone       String?
  regionId    String?
  region      Region?   @relation(fields: [regionId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])
  creditLimit Float     @default(0)
  createdAt   DateTime  @default(now())
  orders      Order[]
  payments    Payment[]
}

model Factory {
  id        String           @id @default(uuid())
  name      String           @unique
  note      String?
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  products  Product[]
  orders    Order[]
  payments  Payment[]
  prices    FactoryPrice[]
  routes    LogisticsRoute[]
}

model Product {
  id        String   @id @default(uuid())
  factoryId String
  factory   Factory  @relation(fields: [factoryId], references: [id])
  name      String
  size      String?
  unit      String   @default("m³")
  costPrice Float    @default(0)
  salePrice Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Vehicle {
  id        String    @id @default(uuid())
  name      String
  plate     String?
  driver    String?
  phone     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  orders    Order[]
  payments  Payment[]
}

model FactoryPrice {
  id             String   @id @default(uuid())
  factoryId      String
  factory        Factory  @relation(fields: [factoryId], references: [id])
  paymentMethod  String   @default("TRANSFER")
  pricePerM3     Float
  dealerBonusPct Float    @default(0)
  effectiveFrom  DateTime @default(now())
}

model LogisticsRoute {
  id              String   @id @default(uuid())
  factoryId       String
  factory         Factory  @relation(fields: [factoryId], references: [id])
  regionId        String
  region          Region   @relation(fields: [regionId], references: [id])
  costPerTruck    Float
  truckCapacityM3 Float    @default(33)
  effectiveFrom   DateTime @default(now())
}

model Order {
  id               String    @id @default(uuid())
  orderNo          String    @unique
  date             DateTime
  agentId          String?
  agent            Agent?    @relation(fields: [agentId], references: [id])
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  factoryId        String
  factory          Factory   @relation(fields: [factoryId], references: [id])
  productId        String
  product          Product   @relation(fields: [productId], references: [id])
  vehicleId        String?
  vehicle          Vehicle?  @relation(fields: [vehicleId], references: [id])
  quantity         Float
  costPricePerUnit Float
  salePricePerUnit Float
  transportFee     Float     @default(0)
  costTotal        Float     @default(0) // we owe factory
  saleTotal        Float     @default(0) // client owes us
  profit           Float     @default(0)
  status           String    @default("NEW") // NEW|CONFIRMED|LOADING|DELIVERING|DELIVERED|COMPLETED|CANCELLED
  note             String?
  createdAt        DateTime  @default(now())
  payments         Payment[]
}

model Payment {
  id        String   @id @default(uuid())
  date      DateTime
  type      String   @default("CLIENT") // CLIENT (in) | FACTORY (out) | VEHICLE (out)
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  factoryId String?
  factory   Factory? @relation(fields: [factoryId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  payerName String?
  method    String   @default("CASH") // CASH | CLICK | TERMINAL | USD | BANK
  usdAmount Float    @default(0)
  rate      Float    @default(0)
  amount    Float
  note      String?
  cashboxId String?
  cashbox   Cashbox? @relation(fields: [cashboxId], references: [id])
  createdAt DateTime @default(now())
}

model Cashbox {
  id           String            @id @default(uuid())
  name         String            @unique
  type         String            @default("CASH") // CASH | CLICK | BANK
  currency     String            @default("UZS")  // UZS | USD
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  transactions CashTransaction[]
  payments     Payment[]
  expenses     Expense[]
}

model CashTransaction {
  id        String   @id @default(uuid())
  cashboxId String
  cashbox   Cashbox  @relation(fields: [cashboxId], references: [id])
  date      DateTime @default(now())
  direction String   @default("IN") // IN | OUT
  amount    Float
  rate      Float    @default(0)
  note      String?
  source    String   @default("MANUAL") // MANUAL | PAYMENT | EXPENSE
  paymentId String?  // set when source=PAYMENT — lets a deleted payment reverse its kassa entry
  expenseId String?  // set when source=EXPENSE — lets a deleted expense reverse its kassa entry
  createdAt DateTime @default(now())
}

model ExpenseCategory {
  id       String    @id @default(uuid())
  name     String    @unique
  expenses Expense[]
}

model Expense {
  id         String           @id @default(uuid())
  date       DateTime
  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id])
  amount     Float
  cashboxId  String?
  cashbox    Cashbox?         @relation(fields: [cashboxId], references: [id])
  note       String?
  createdAt  DateTime         @default(now())
}
