# ─────────────────────────── API (apps/api/.env) ───────────────────────────
# The dev bootstrap (scripts/ensure-env-db.mjs) provisions a local PostgreSQL
# cluster in .pgdata on port 5433 and writes apps/api/.env automatically. These
# are the real production values you set by hand on a server.

# PostgreSQL only (the Decimal ledger requires it — SQLite is not supported).
DATABASE_URL="postgresql://postgres@localhost:5433/smartblok"

# Long random secret (min 16 chars, 32+ recommended). App refuses to boot if weak.
JWT_SECRET="generate-a-long-random-secret-min-32-chars"

# Access-token lifetime (read as JWT_EXPIRES; defaults to 12h if unset).
JWT_EXPIRES="12h"

API_PORT=4000

# Comma-separated allowed frontend origins. REQUIRED when NODE_ENV=production
# (the app fails fast if unset in prod); dev falls back to http://localhost:5173.
CORS_ORIGIN="http://localhost:5173"

# Set to "production" on a real server. Enables strict CORS, disables demo-user
# seeding, and hardens defaults.
# NODE_ENV="production"

# Number of reverse proxies in front of the API (for correct client IP / rate
# limiting). Default 1. Set 0 when the API is exposed directly.
# TRUST_PROXY_HOPS=1

# Set to 1 to seed the demo login users (admin/hisob/kassa/jamol) even in
# production. Off by default when NODE_ENV=production.
# SEED_DEMO_USERS=1

# ─────────────────────────── WEB (apps/web) ────────────────────────────────
# Only needed if the SPA is served on a DIFFERENT origin than the API. When the
# API serves the built SPA (ServeStaticModule, same origin) leave this unset and
# the frontend uses the relative "/api" path.
# VITE_API_URL="https://api.smartblok.uz/api"
