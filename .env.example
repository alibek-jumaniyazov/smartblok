# ---- API ----
# Dev default uses SQLite (zero setup). For production switch to PostgreSQL:
#   provider = "postgresql" in apps/api/prisma/schema.prisma and set:
#   DATABASE_URL="postgresql://smartblok:smartblok@localhost:5432/smartblok?schema=public"
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
API_PORT=4000
CORS_ORIGIN="http://localhost:5173"

# ---- WEB ----
VITE_API_URL="http://localhost:4000/api"
